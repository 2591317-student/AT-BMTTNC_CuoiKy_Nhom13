# API-specific settings
# Shared keys (API_KEY, HMAC_SECRET, AES_KEY) đọc từ root .env

TIMESTAMP_TOLERANCE=30
DB_PATH=edge_data.db

# HTTPS — set USE_HTTPS=true to enable TLS with a self-signed (adhoc) certificate.
# Requires: pip install pyOpenSSL
# Note: browser will show a security warning for self-signed certs in demo.
USE_HTTPS=false

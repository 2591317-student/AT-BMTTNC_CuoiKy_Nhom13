# Copy this file to .env in the relevant module directory and fill in real values.
# NEVER commit the actual .env file to git.

API_KEY=your-api-key-here
HMAC_SECRET=your-hmac-secret-here
AES_KEY=your-32-byte-aes-key-here

# Sensor-specific
API_ENDPOINT=http://localhost:5000/api/data
DEVICE_ID=sensor-001
SEND_INTERVAL=2
TEMP_MIN=30.0
TEMP_MAX=40.0
